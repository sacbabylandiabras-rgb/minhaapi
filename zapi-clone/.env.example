# App
PORT=3000
NODE_ENV=development
API_KEY=your-master-api-key-here

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zapiclone

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Sessions (onde salva os arquivos de sessão do Baileys)
SESSIONS_DIR=./sessions

# Webhook
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY=5000
